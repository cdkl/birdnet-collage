# Required: Birdnet-GO server URL (http or https)
BIRDNET_GO_URL=http://your-birdnet-go-ip:8080

# Optional: Bearer token if Birdnet-GO requires authentication
# BIRDNET_GO_TOKEN=

# Optional: Site title shown in the browser tab and header (default: birdnet collage)
# SITE_TITLE=birdnet collage

# Optional: Override the host port (default: 8081)
# PORT=80

# Optional: Probability a bird appears in flight (spread-wing) pose (default: 0.15)
# Set to 0.0 for all perched, 1.0 for all flight poses.
# FLIGHT_POSE_PROB=0.15